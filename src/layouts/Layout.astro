---
interface Props {
  title: string;
}

const { title } = Astro.props;
const currentDate = new Date().toLocaleDateString("fr-FR", {
  weekday: "long",
  day: "numeric",
  month: "long",
  year: "numeric",
});
import "../styles/reset.css";
import "../styles/global.css";
import BaseHead from "../components/BaseHead.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <BaseHead title={SITE_TITLE} />
  </head>
  <body>
    <header>
      <h1>The French Dev</h1>
      <hr />
      <hr />
      <div class="subtitle">
        <span>placeholder1</span>
        <span class="date">{currentDate}</span>
        <span>placeholder2</span>
      </div>
      <hr />
      <hr />
    </header>
    <slot />
    <style is:global>
      @import url("https://fonts.googleapis.com/css2?family=Oswald:wght@400&display=swap");

      body {
        padding-top: 3vh;
        margin: auto;
        max-width: 125ch;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      header {
        width: 100%;
      }

      header h1 {
        font-family: Oswald;
        text-transform: uppercase;
        font-size: clamp(25px, 10vw, 80px);
        user-select: none;
        text-align: center;
        margin-bottom: 20px;
      }

      header hr {
        margin: 1px 0;
      }

      header .subtitle {
        display: flex;
        justify-content: space-between;
        padding: 5px 3%;
      }
    </style>
  </body>
</html>
